{
  "name": "@arkafund/catalog-api",
  "version": "0.1.0",
  "description": "Indexed catalog and snapshot API for Arkafund discovery surfaces",
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "types": "./dist/src/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "regen:bindings": "bash ./scripts/generate-bindings.sh",
    "test:unit": "npm run build && node --test dist/tests/unit/*.test.js",
    "test:integration": "npm run build && node --test dist/tests/integration/http-api.test.js dist/tests/integration/graphql-runner.test.js dist/tests/integration/graphql-mirror.test.js",
    "test:integration:live": "npm run build && node --test dist/tests/integration/live-indexer.test.js",
    "test:e2e:live": "npm run build && node --test dist/tests/e2e/live-api.test.js",
    "test:e2e": "bash ./scripts/e2e-local.sh && npm run build && node --test dist/tests/e2e/graphql-backend.test.js"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.1.1",
    "buffer": "6.0.3",
    "fastify": "^5.8.4"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
